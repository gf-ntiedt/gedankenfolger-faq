{
    "name": "gedankenfolger/gedankenfolger-faq",
    "description": "TYPO3 14 FAQ extension with Content Blocks, Site Set, Schema, JS, SCSS.",
    "version": "14.2.0",
    "type": "typo3-cms-extension",
    "license": [
        "GPL-2.0-or-later"
    ],
    "authors": [
        {
            "name": "Niels Tiedt, Gedankenfolger GmbH",
            "email": "niels.tiedt@gedankenfolger.de",
            "homepage": "https://www.gedankenfolger.de",
            "role": "Developer"
        }
    ],
    "require": {
        "typo3/cms-core": "^14.0",
        "friendsoftypo3/content-blocks": "^2.0"
    },
    "suggest": {
        "brotkrueml/schema": "For schema.org FAQPage structured data output",
        "wapplersystems/ws-scss": "For SCSS compilation of faq.scss; alternatively set faq.css.default = 1"
    },
    "autoload": {
        "psr-4": {
            "Gedankenfolger\\GedankenfolgerFaq\\": "Classes/"
        }
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "gedankenfolger_faq",
            "Package": {
                "providesPackages": {}
            }
        }
    }
}
